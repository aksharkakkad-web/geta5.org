  "calculator_allowed": true,
  "total_points": 9,
  "stimulus": "The graphs of the polar curves $r = 3$ and $r = 4 - 2\\sin\\theta$ are shown in the figure above. The curves intersect when $\\theta = \\dfrac{\\pi}{6}$ and $\\theta = \\dfrac{5\\pi}{6}$.",
  "stimulus_image": "/data/ap-calculus-bc/frq/images/calc-bc-2013-frq-2-stimulus.png",
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Let $S$ be the shaded region that is inside the graph of $r = 3$ and also inside the graph of $r = 4 - 2\\sin\\theta$. Find the area of $S$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": true,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct area integral setup using the appropriate polar area formula and correct bounds",
          "alternatives": [
            {
              "required_elements": [
                "$A = \\dfrac{1}{2}\\displaystyle\\int_{\\pi/6}^{5\\pi/6} (4-2\\sin\\theta)^2\\,d\\theta + \\dfrac{1}{2}\\int_{-\\pi/6}^{\\pi/6} 9\\,d\\theta$ (or equivalent symmetric setup)",
                "Area $= \\dfrac{1}{2}\\displaystyle\\int_0^{\\pi/6} 9\\,d\\theta + \\dfrac{1}{2}\\int_{\\pi/6}^{5\\pi/6}(4-2\\sin\\theta)^2\\,d\\theta + \\dfrac{1}{2}\\int_{5\\pi/6}^{2\\pi} 9\\,d\\theta$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct integrand(s) with correct limits of integration",
          "alternatives": [
            {
              "required_elements": [
                "Integrand $(4-2\\sin\\theta)^2$ on the arc where $r = 4 - 2\\sin\\theta < 3$",
                "Integrand $9$ (i.e., $r = 3$) on the arcs where the circle is interior"
              ]
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct numerical area",
          "alternatives": [
            {
              "required_elements": [
                "$A \\approx 25.590$ square units"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "A particle moves along the polar curve $r = 4 - 2\\sin\\theta$ so that at time $t$ seconds, $\\theta = t^2$. Find the time $t$ in the interval $1 \\leq t \\leq 2$ for which the $x$-coordinate of the particle's position is $-1$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct expression for the $x$-coordinate in terms of $t$",
          "alternatives": [
            {
              "required_elements": [
                "$x = r\\cos\\theta = (4 - 2\\sin(t^2))\\cos(t^2)$"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Sets $x = -1$ and uses calculator to solve",
          "alternatives": [
            {
              "required_elements": [
                "$(4 - 2\\sin(t^2))\\cos(t^2) = -1$ on $[1, 2]$"
              ]
            }
          ]
        },
        {
          "point_id": "b3",
          "point_value": 1,
          "description": "Correct value of $t$",
          "alternatives": [
            {
              "required_elements": [
                "$t \\approx 1.489$ seconds"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "For the particle described in part (b), find the position vector in terms of $t$. Find the velocity vector at time $t = 1.5$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct position vector components expressed in terms of $t$",
          "alternatives": [
            {
              "required_elements": [
                "$\\vec{r}(t) = \\langle (4-2\\sin(t^2))\\cos(t^2),\\; (4-2\\sin(t^2))\\sin(t^2) \\rangle$"
              ]
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct method for finding the velocity vector (differentiating $x(t)$ and $y(t)$)",
          "alternatives": [
            {
              "required_elements": [
                "$\\vec{v}(t) = \\left\\langle \\dfrac{dx}{dt},\\, \\dfrac{dy}{dt} \\right\\rangle$ using chain rule with $\\theta = t^2$, $\\dfrac{d\\theta}{dt} = 2t$"
              ]
            }
          ]
        },
        {
          "point_id": "c3",
          "point_value": 1,
          "description": "Correct numerical velocity vector at $t = 1.5$",
          "alternatives": [
            {
              "required_elements": [
                "$\\vec{v}(1.5) \\approx \\langle -4.402,\\; 6.161 \\rangle$ (or equivalent decimal approximation)"
              ]
            }
          ]
        }
      ]
    }
  ],
