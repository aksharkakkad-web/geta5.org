  "stimulus": "At time $t$, the position of a particle moving in the $xy$-plane is given by the parametric functions $(x(t),\\, y(t))$, where $\\dfrac{dx}{dt} = t^2 + \\sin(3t^2)$. The graph of $y$, consisting of three line segments, is shown in the figure above. At $t = 0$, the particle is at position $(5, 1)$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Find the position of the particle at $t = 3$.",
      "point_value": 3,
      "scoring_notes": "Use $x(3) = x(0) + \\int_0^3 \\frac{dx}{dt}\\,dt$ and read $y(3)$ from the graph of $y$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct integral expression for $x(3)$",
          "alternatives": [
            {
              "required_elements": [
                "$x(3) = 5 + \\int_0^3 (t^2 + \\sin(3t^2))\\,dt$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct numerical value for $x(3)$ (calculator required)",
          "alternatives": [
            {
              "required_elements": [
                "$x(3) \\approx 5 + 9.405 = 14.405$ (accept values consistent with calculator)"
              ]
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct value for $y(3)$ read from the piecewise-linear graph",
          "alternatives": [
            {
              "required_elements": [
                "$y(3) = -2$ (read from graph); position is approximately $(14.405,\\, -2)$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Find the slope of the line tangent to the path of the particle at $t = 3$.",
      "point_value": 1,
      "scoring_notes": "Slope $= \\dfrac{dy/dt}{dx/dt}$ evaluated at $t = 3$. Read $dy/dt$ at $t=3$ from the graph of $y$ (slope of the line segment).",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct tangent slope using $dy/dx = (dy/dt)/(dx/dt)$ at $t=3$",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{dy}{dx}\\bigg|_{t=3} = \\dfrac{dy/dt}{dx/dt}\\bigg|_{t=3}$; with $dy/dt$ from graph and $dx/dt = 9 + \\sin(27)$ at $t=3$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "Find the speed of the particle at $t = 3$.",
      "point_value": 2,
      "scoring_notes": "Speed $= \\sqrt{(dx/dt)^2 + (dy/dt)^2}$ evaluated at $t = 3$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct speed formula",
          "alternatives": [
            {
              "required_elements": [
                "$\\text{speed} = \\sqrt{\\left(\\dfrac{dx}{dt}\\right)^2 + \\left(\\dfrac{dy}{dt}\\right)^2}\\bigg|_{t=3}$"
              ]
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct numerical answer (calculator required)",
          "alternatives": [
            {
              "required_elements": [
                "Numerical value consistent with $\\sqrt{(dx/dt|_{t=3})^2 + (dy/dt|_{t=3})^2}$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "d",
      "prompt": "Find the total distance traveled by the particle from $t = 0$ to $t = 2$.",
      "point_value": 3,
      "scoring_notes": "Arc length $= \\int_0^2 \\sqrt{(dx/dt)^2 + (dy/dt)^2}\\,dt$. Evaluate with a calculator.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
