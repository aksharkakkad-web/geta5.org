  "stimulus": "A function $f$ has derivatives of all orders at $x = 0$. Let $P_n(x)$ denote the $n$th-degree Taylor polynomial for $f$ about $x = 0$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "It is known that $f(0) = -4$ and that $P_1\\!\\left(\\dfrac{1}{2}\\right) = -3$. Show that $f'(0) = 2$.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correctly writes $P_1(x)$ in terms of $f(0)$ and $f'(0)$",
          "official_rubric": "1 point: uses $P_1(x)$ — $P_1(x) = f(0) + f'(0)x = -4 + f'(0)x$, then $P_1\\!\\left(\\frac{1}{2}\\right) = -4 + f'(0)\\cdot\\frac{1}{2} = -3$",
          "sample_responses": [
            {
              "response": "$P_1(x) = -4 + f'(0)x$; substituting $x=\\frac{1}{2}$: $-4 + f'(0)\\cdot\\frac{1}{2} = -3$.",
              "earned": true,
              "commentary": "Correctly writes the first-degree Taylor polynomial and substitutes the given value $P_1(1/2)=-3$.",
              "source": "cb_guideline"
            },
            {
              "response": "$P_1(1/2) = f(1/2) = -3$, so $f'(0) = (-3-(-4))/(1/2-0) = 2$.",
              "earned": false,
              "commentary": "Treats the polynomial as if $P_1(1/2) = f(1/2)$; the polynomial value matches the linear approximation, but this reasoning conflates the polynomial with the function. The required approach is to write $P_1$ and substitute.",
              "source": "synthesized"
            }
          ],
          "alternatives": [
            {
              "required_elements": [
                "$P_1(x) = f(0) + f'(0)\\cdot x = -4 + f'(0)\\cdot x$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correctly substitutes $x = \\frac{1}{2}$ and solves to show $f'(0) = 2$",
          "official_rubric": "1 point: verifies $f'(0) = 2$ — $f'(0)\\cdot\\frac{1}{2} = 1 \\Rightarrow f'(0) = 2$",
          "sample_responses": [
            {
              "response": "$f'(0)\\cdot\\frac{1}{2} = -3-(-4) = 1 \\Rightarrow f'(0) = 2$. $\\square$",
              "earned": true,
              "commentary": "Correctly solves for $f'(0)$ and verifies the result equals 2.",
              "source": "cb_guideline"
            },
            {
              "response": "$f'(0) = -3/(-4) = 3/4$",
              "earned": false,
              "commentary": "Divides the output value by the input value rather than solving $-4 + f'(0)/2 = -3$ algebraically.",
              "source": "synthesized"
            }
          ],
          "alternatives": [
            {
              "required_elements": [
                "$P_1\\!\\left(\\frac{1}{2}\\right) = -4 + f'(0)\\cdot\\frac{1}{2} = -3$",
                "$f'(0)\\cdot\\frac{1}{2} = 1 \\Rightarrow f'(0) = 2$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "It is known that $f''(0) = -\\dfrac{2}{3}$ and $f'''(0) = \\dfrac{2}{3}$. Find $P_3(x)$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct first two terms of $P_3(x)$",
          "official_rubric": "1 point: first two terms — $-4 + 2x$",
          "sample_responses": [
            {
              "response": "$P_3(x) = -4 + 2x + \\cdots$",
              "earned": true,
              "commentary": "Correctly uses $f(0)=-4$ and $f'(0)=2$ for the constant and linear terms.",
              "source": "cb_guideline"
            },
            {
              "response": "$P_3(x) = -4 + (-4)x + \\cdots$",
              "earned": false,
              "commentary": "Uses $f(0)=-4$ as the coefficient of $x$ rather than $f'(0)=2$.",
              "source": "synthesized"
