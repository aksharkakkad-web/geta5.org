{
  "id": "calc-bc-2013-frq-6",
  "subject": "ap-calculus-bc",
  "year": 2013,
  "source": "released",
  "title": "Taylor / Maclaurin Series",
  "frq_type": "multi_part_math",
  "related_units": [
    2,
    10
  ],
  "calculator_allowed": false,
  "total_points": 9,
  "stimulus": "A function $f$ has derivatives of all orders at $x = 0$. Let $P_n(x)$ denote the $n$th-degree Taylor polynomial for $f$ about $x = 0$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "It is known that $f(0) = -4$ and that $P_1\\!\\left(\\dfrac{1}{2}\\right) = -3$. Show that $f'(0) = 2$.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correctly writes $P_1(x)$ in terms of $f(0)$ and $f'(0)$",
          "alternatives": [
            {
              "required_elements": [
                "$P_1(x) = f(0) + f'(0)\\cdot x = -4 + f'(0)\\cdot x$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correctly substitutes $x = \\frac{1}{2}$ and solves to show $f'(0) = 2$",
          "alternatives": [
            {
              "required_elements": [
                "$P_1\\!\\left(\\frac{1}{2}\\right) = -4 + f'(0)\\cdot\\frac{1}{2} = -3$",
                "$f'(0)\\cdot\\frac{1}{2} = 1 \\Rightarrow f'(0) = 2$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "It is known that $f''(0) = -\\dfrac{2}{3}$ and $f'''(0) = \\dfrac{2}{3}$. Find $P_3(x)$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct general form of $P_3(x)$ as a Taylor polynomial about $x = 0$",
          "alternatives": [
            {
              "required_elements": [
                "$P_3(x) = f(0) + f'(0)x + \\dfrac{f''(0)}{2!}x^2 + \\dfrac{f'''(0)}{3!}x^3$"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct coefficients substituted",
          "alternatives": [
            {
              "required_elements": [
                "$P_3(x) = -4 + 2x + \\dfrac{-2/3}{2}x^2 + \\dfrac{2/3}{6}x^3 = -4 + 2x - \\dfrac{1}{3}x^2 + \\dfrac{1}{9}x^3$"
              ]
            }
          ]
        },
        {
          "point_id": "b3",
          "point_value": 1,
          "description": "Correct final expression for $P_3(x)$",
          "alternatives": [
            {
              "required_elements": [
                "$P_3(x) = -4 + 2x - \\dfrac{1}{3}x^2 + \\dfrac{1}{9}x^3$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "The function $h$ has first derivative given by $h'(x) = f(2x)$. It is known that $h(0) = 7$. Find the third-degree Taylor polynomial for $h$ about $x = 0$.",
      "point_value": 4,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correctly uses $h'(x) = f(2x)$ and writes the Taylor series for $h'(x)$ by substituting $2x$ into $P_3(x)$",
          "alternatives": [
            {
              "required_elements": [
                "$h'(x) = f(2x) \\approx -4 + 2(2x) - \\dfrac{1}{3}(2x)^2 + \\dfrac{1}{9}(2x)^3$",
                "$h'(x) \\approx -4 + 4x - \\dfrac{4}{3}x^2 + \\dfrac{8}{9}x^3$"
              ]
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correctly integrates to find $h(x) = h(0) + \\int_0^x h'(t)\\,dt$",
          "alternatives": [
            {
              "required_elements": [
                "$h(x) = 7 + \\displaystyle\\int_0^x h'(t)\\,dt$"
              ]
            }
          ]
        },
        {
          "point_id": "c3",
          "point_value": 1,
          "description": "Correct antiderivative of the Taylor polynomial for $h'(x)$",
          "alternatives": [
            {
              "required_elements": [
                "$\\displaystyle\\int_0^x\\left(-4 + 4t - \\frac{4}{3}t^2\\right)dt = -4x + 2x^2 - \\frac{4}{9}x^3$"
              ]
            }
          ]
        },
        {
          "point_id": "c4",
          "point_value": 1,
          "description": "Correct third-degree Taylor polynomial for $h$ with correct constant $h(0) = 7$",
          "alternatives": [
            {
              "required_elements": [
                "$Q_3(x) = 7 - 4x + 2x^2 - \\dfrac{4}{9}x^3$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
