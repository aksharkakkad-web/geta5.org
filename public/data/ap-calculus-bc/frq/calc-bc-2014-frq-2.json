  "title": "Polar Curves: Area and Rate of Change",
  "frq_type": "multi_part_math",
  "related_units": [
    1,
    3,
    4,
    6,
    9
  ],
  "calculator_allowed": true,
  "total_points": 9,
  "stimulus": "The graphs of the polar curves $r = 3$ and $r = 3 - 2\\sin(2\\theta)$ are shown in the figure for $0 \\leq \\theta \\leq \\pi$.",
  "stimulus_image": "/data/ap-calculus-bc/frq/images/calc-bc-2014-frq-2-stimulus.png",
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Let $R$ be the shaded region that is inside the graph of $r = 3$ and inside the graph of $r = 3 - 2\\sin(2\\theta)$, for $0 \\leq \\theta \\leq \\pi$. Find the area of $R$.",
      "point_value": 3,
      "scoring_notes": "The shaded region is where $r = 3 - 2\\sin(2\\theta) \\leq 3$, i.e., where $\\sin(2\\theta) \\geq 0$, which occurs on $[0, \\pi/2]$ and $[\\pi, \\pi]$ within $[0,\\pi]$. The area integral uses $r = 3 - 2\\sin(2\\theta)$ on those subintervals and $r = 3$ elsewhere.",
      "requires_drawing": true,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct identification of limits and which curve bounds the region",
          "alternatives": [
            {
              "required_elements": [
                "Recognizes $r = 3 - 2\\sin(2\\theta) \\leq 3$ when $\\sin(2\\theta) \\geq 0$, i.e., on $[0, \\tfrac{\\pi}{2}]$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct area integral set up",
          "alternatives": [
            {
              "required_elements": [
                "Area $= \\dfrac{1}{2}\\displaystyle\\int_0^{\\pi/2}(3-2\\sin(2\\theta))^2\\,d\\theta + \\dfrac{1}{2}\\displaystyle\\int_{\\pi/2}^{\\pi} 9\\,d\\theta$"
              ]
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct numerical answer",
          "alternatives": [
            {
              "required_elements": [
                "Area $\\approx 10.370$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "For the curve $r = 3 - 2\\sin(2\\theta)$, find the value of $\\dfrac{dy}{dx}$ at $\\theta = \\dfrac{\\pi}{6}$.",
      "point_value": 3,
      "scoring_notes": "Use parametric form $x = r\\cos\\theta$, $y = r\\sin\\theta$ and differentiate.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct expressions for $\\dfrac{dx}{d\\theta}$ and $\\dfrac{dy}{d\\theta}$",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{dx}{d\\theta} = \\dfrac{dr}{d\\theta}\\cos\\theta - r\\sin\\theta$, $\\dfrac{dy}{d\\theta} = \\dfrac{dr}{d\\theta}\\sin\\theta + r\\cos\\theta$, where $\\dfrac{dr}{d\\theta} = -4\\cos(2\\theta)$"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct evaluation at $\\theta = \\pi/6$",
          "alternatives": [
            {
              "required_elements": [
                "Substitutes $\\theta = \\dfrac{\\pi}{6}$, $r = 3 - 2\\sin\\!\\left(\\dfrac{\\pi}{3}\\right) = 3 - \\sqrt{3}$, $\\dfrac{dr}{d\\theta} = -4\\cos\\!\\left(\\dfrac{\\pi}{3}\\right) = -2$ correctly"
              ]
            }
          ]
        },
        {
          "point_id": "b3",
          "point_value": 1,
          "description": "Correct numerical value of $\\dfrac{dy}{dx}$",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{dy}{dx}\\bigg|_{\\theta=\\pi/6} \\approx -2.366$ (or exact equivalent)"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "The distance between the two curves changes for $0 < \\theta < \\dfrac{\\pi}{2}$. Find the rate at which the distance between the two curves is changing with respect to $\\theta$ when $\\theta = \\dfrac{\\pi}{3}$.",
      "point_value": 1,
      "scoring_notes": "The radial distance between curves is $D(\\theta) = 3 - (3 - 2\\sin(2\\theta)) = 2\\sin(2\\theta)$ for $0 < \\theta < \\pi/2$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct rate of change of distance",
          "alternatives": [
            {
              "required_elements": [
                "$D(\\theta) = 2\\sin(2\\theta)$, $D'(\\theta) = 4\\cos(2\\theta)$, $D'\\!\\left(\\dfrac{\\pi}{3}\\right) = 4\\cos\\!\\left(\\dfrac{2\\pi}{3}\\right) = -2$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "d",
      "prompt": "A particle is moving along the curve $r = 3 - 2\\sin(2\\theta)$ so that $\\dfrac{d\\theta}{dt} = 3$ for all times $t \\geq 0$. Find the value of $\\dfrac{dr}{dt}$ at $\\theta = \\dfrac{\\pi}{3}$.",
      "point_value": 2,
      "scoring_notes": "Apply chain rule: $\\dfrac{dr}{dt} = \\dfrac{dr}{d\\theta} \\cdot \\dfrac{d\\theta}{dt}$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "d1",
          "point_value": 1,
          "description": "Correct application of chain rule",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{dr}{dt} = \\dfrac{dr}{d\\theta} \\cdot \\dfrac{d\\theta}{dt} = -4\\cos(2\\theta) \\cdot 3$"
              ]
            }
          ]
        },
        {
          "point_id": "d2",
          "point_value": 1,
          "description": "Correct numerical answer",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{dr}{dt}\\bigg|_{\\theta=\\pi/3} = -4\\cos\\!\\left(\\dfrac{2\\pi}{3}\\right) \\cdot 3 = -4\\!\\left(-\\tfrac{1}{2}\\right)\\!(3) = 6$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
