{
  "id": "calc-bc-2013-frq-5",
  "subject": "ap-calculus-bc",
  "year": 2013,
  "source": "released",
  "title": "Differential Equations (Separable)",
  "frq_type": "multi_part_math",
  "related_units": [
    1,
    2,
    6,
    7
  ],
  "calculator_allowed": false,
  "total_points": 9,
  "stimulus": "Consider the differential equation $\\dfrac{dy}{dx} = y^2(2x + 2)$. Let $y = f(x)$ be the particular solution to the differential equation with initial condition $f(0) = -1$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Find $\\displaystyle\\lim_{x \\to 0} \\frac{f(x) + 1}{\\sin x}$. Show the work that leads to your answer.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Recognizes the limit as $f'(0)$ via L'Hopital's rule or the definition of the derivative, and correctly computes $f'(0)$",
          "alternatives": [
            {
              "required_elements": [
                "Since $f(0) = -1$, the limit $\\displaystyle\\lim_{x \\to 0} \\frac{f(x) + 1}{\\sin x}$ is of the form $\\frac{0}{0}$",
                "Applying L'Hopital's rule: $\\displaystyle\\lim_{x \\to 0} \\frac{f'(x)}{\\cos x} = \\frac{f'(0)}{1} = f'(0)$",
                "$f'(0) = \\bigl(f(0)\\bigr)^2(2\\cdot 0 + 2) = (-1)^2(2) = 2$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct limit value",
          "alternatives": [
            {
              "required_elements": [
                "$\\displaystyle\\lim_{x \\to 0} \\frac{f(x)+1}{\\sin x} = 2$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Use Euler's method, starting at $x = 0$ with two steps of equal size, to approximate $f(1)$.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct first Euler step",
          "alternatives": [
            {
              "required_elements": [
                "Step size $h = \\frac{1}{2}$",
                "$y_1 = f(0) + h \\cdot f'(0) = -1 + \\frac{1}{2}\\cdot(-1)^2(0+2) = -1 + \\frac{1}{2}\\cdot 2 = -1 + 1 = 0$"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct second Euler step and approximation",
          "alternatives": [
            {
              "required_elements": [
                "At $x = \\frac{1}{2}$, $y = 0$: $y_2 = 0 + \\frac{1}{2}\\cdot (0)^2\\left(2\\cdot\\frac{1}{2}+2\\right) = 0 + 0 = 0$",
                "$f(1) \\approx 0$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "Find $y = f(x)$, the particular solution to the differential equation with initial condition $f(0) = -1$.",
      "point_value": 5,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct separation of variables",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{dy}{y^2} = (2x + 2)\\,dx$"
              ]
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct antiderivatives on both sides",
          "alternatives": [
            {
              "required_elements": [
                "$-\\dfrac{1}{y} = x^2 + 2x + C$"
              ]
            }
          ]
        },
        {
          "point_id": "c3",
          "point_value": 1,
          "description": "Correct constant $C$ using initial condition $f(0) = -1$",
          "alternatives": [
            {
              "required_elements": [
                "$-\\dfrac{1}{-1} = 0 + 0 + C \\Rightarrow C = 1$"
              ]
            }
          ]
        },
        {
          "point_id": "c4",
          "point_value": 1,
          "description": "Correct algebraic solving for $y$",
          "alternatives": [
            {
              "required_elements": [
                "$-\\dfrac{1}{y} = x^2 + 2x + 1 = (x+1)^2$",
                "$y = -\\dfrac{1}{(x+1)^2}$"
              ]
            }
          ]
        },
        {
          "point_id": "c5",
          "point_value": 1,
          "description": "Correct domain stated",
          "alternatives": [
            {
              "required_elements": [
                "$f(x) = -\\dfrac{1}{(x+1)^2}$, valid for $x > -1$ (or $x \\neq -1$, with $x > -1$ because of the initial condition)"
              ]
            }
          ]
        }
      ]
    }
  ]
}
