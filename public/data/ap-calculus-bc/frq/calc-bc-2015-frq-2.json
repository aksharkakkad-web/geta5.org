  "total_points": 9,
  "stimulus": "At time $t \\geq 0$, a particle moving along a curve in the $xy$-plane has position $\\bigl(x(t),\\, y(t)\\bigr)$ with velocity vector $\\mathbf{v}(t) = \\left\\langle \\cos(t^2),\\, e^{0.5t} \\right\\rangle$. At $t = 1$, the particle is at the point $(3, 5)$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Find the $x$-coordinate of the position of the particle at time $t = 2$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct integral expression for $x(2)$ using the Fundamental Theorem: $x(2) = x(1) + \\int_1^2 \\cos(t^2)\\,dt$",
          "alternatives": [
            {
              "required_elements": [
                "$x(2) = 3 + \\int_1^2 \\cos(t^2)\\,dt$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct numerical evaluation of the integral",
          "alternatives": [
            {
              "required_elements": [
                "$\\int_1^2 \\cos(t^2)\\,dt \\approx -0.450$"
              ]
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct final answer: $x(2) \\approx 3 + (-0.450) \\approx 2.550$",
          "alternatives": [
            {
              "required_elements": [
                "$x(2) \\approx 2.550$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "For $0 < t < 1$, there is a point on the curve at which the line tangent to the curve has a slope of $2$. At what time is the particle at that point? Give a decimal approximation.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct slope expression: $\\dfrac{dy}{dx} = \\dfrac{dy/dt}{dx/dt} = \\dfrac{e^{0.5t}}{\\cos(t^2)}$ set equal to $2$",
          "alternatives": [
            {
              "required_elements": [
                "$\\dfrac{e^{0.5t}}{\\cos(t^2)} = 2$"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct answer: $t \\approx 0.840$",
          "alternatives": [
            {
              "required_elements": [
                "$t \\approx 0.840$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "Find the time at which the speed of the particle is $3$. Give a decimal approximation.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct speed expression set equal to $3$: $\\sqrt{\\left[\\cos(t^2)\\right]^2 + \\left[e^{0.5t}\\right]^2} = 3$",
          "alternatives": [
            {
              "required_elements": [
                "$\\sqrt{\\cos^2(t^2) + e^{t}} = 3$"
              ]
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct answer: $t \\approx 2.191$",
          "alternatives": [
            {
              "required_elements": [
                "$t \\approx 2.191$"
              ]
            }
          ]
        }
      ]
    },
    {
      "letter": "d",
      "prompt": "Find the total distance traveled by the particle from time $t = 0$ to time $t = 1$.",
      "point_value": 2,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "d1",
