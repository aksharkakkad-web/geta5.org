{
  "subject": "ap-calculus-bc",
  "unit": "unit-3",
  "unit_name": "Differentiation: Composite, Implicit, and Inverse Functions",
  "cards": [
    {
      "id": "calcbc-u3-d001",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule: derivative of $f(g(x))$",
      "answer": "\\frac{d}{dx}[f(g(x))] = f'(g(x)) \\cdot g'(x)",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d002",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule in Leibniz notation",
      "answer": "\\frac{dy}{dx} = \\frac{dy}{du} \\cdot \\frac{du}{dx}",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d003",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of an inverse function at a point",
      "answer": "(f^{-1})'(x) = \\frac{1}{f'(f^{-1}(x))}",
      "is_key_term": true,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d004",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\arcsin x$",
      "answer": "\\frac{d}{dx}[\\arcsin x] = \\frac{1}{\\sqrt{1 - x^2}}",
      "is_key_term": true,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d005",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\arccos x$",
      "answer": "\\frac{d}{dx}[\\arccos x] = -\\frac{1}{\\sqrt{1 - x^2}}",
      "is_key_term": true,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d006",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\arctan x$",
      "answer": "\\frac{d}{dx}[\\arctan x] = \\frac{1}{1 + x^2}",
      "is_key_term": true,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d007",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\text{arcsec}\\, x$",
      "answer": "\\frac{d}{dx}[\\text{arcsec}\\, x] = \\frac{1}{|x|\\sqrt{x^2 - 1}}",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d008",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule applied to $e^{g(x)}$",
      "answer": "\\frac{d}{dx}[e^{g(x)}] = e^{g(x)} \\cdot g'(x)",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d009",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule applied to $\\ln(g(x))$",
      "answer": "\\frac{d}{dx}[\\ln(g(x))] = \\frac{g'(x)}{g(x)}",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d010",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule applied to $[g(x)]^n$",
      "answer": "\\frac{d}{dx}[[g(x)]^n] = n[g(x)]^{n-1} \\cdot g'(x)",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d011",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Implicit differentiation step for $y^n$ with respect to $x$",
      "answer": "\\frac{d}{dx}[y^n] = n y^{n-1} \\cdot \\frac{dy}{dx}",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d012",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Second derivative (Leibniz notation)",
      "answer": "\\frac{d^2 y}{dx^2} = \\frac{d}{dx}\\!\\left[\\frac{dy}{dx}\\right]",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d013",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Second derivative from implicit differentiation — general form after solving for $\\frac{dy}{dx}$",
      "answer": "\\frac{d^2 y}{dx^2} = \\frac{d}{dx}\\!\\left[\\frac{dy}{dx}\\right], \\text{ substituting } \\frac{dy}{dx} \\text{ back in}",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d014",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule — triple composition: derivative of $f(g(h(x)))$",
      "answer": "\\frac{d}{dx}[f(g(h(x)))] = f'(g(h(x))) \\cdot g'(h(x)) \\cdot h'(x)",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d015",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $a^{g(x)}$ for constant $a > 0$",
      "answer": "\\frac{d}{dx}[a^{g(x)}] = a^{g(x)} \\ln a \\cdot g'(x)",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d016",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Logarithmic differentiation — derivative of $[f(x)]^{g(x)}$",
      "answer": "\\frac{d}{dx}[[f(x)]^{g(x)}] = [f(x)]^{g(x)} \\cdot \\frac{d}{dx}[g(x)\\ln f(x)]",
      "is_key_term": true,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d017",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule applied to $\\sin(g(x))$",
      "answer": "\\frac{d}{dx}[\\sin(g(x))] = \\cos(g(x)) \\cdot g'(x)",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d018",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule applied to $\\cos(g(x))$",
      "answer": "\\frac{d}{dx}[\\cos(g(x))] = -\\sin(g(x)) \\cdot g'(x)",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d019",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Chain Rule applied to $\\tan(g(x))$",
      "answer": "\\frac{d}{dx}[\\tan(g(x))] = \\sec^2(g(x)) \\cdot g'(x)",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d020",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "A function $h$ is formed by applying one function to the output of another, written $h(x) = f(g(x))$. What is this called?",
      "answer": "composite function",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d021",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "The differentiation technique where you differentiate both sides of an equation with respect to $x$ without first solving for $y$ explicitly is called what?",
      "answer": "implicit differentiation",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d022",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "The $n$th derivative of $f$ is the result of differentiating $f$ exactly $n$ times in succession. What category of derivatives is this?",
      "answer": "higher-order derivatives",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d023",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "The derivative that gives the rate of change of the slope of a function — i.e., $f''(x)$ — is called the what?",
      "answer": "second derivative",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d024",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "When differentiating $y^2$ with respect to $x$ implicitly, you get $2y \\cdot \\frac{dy}{dx}$ because of what rule?",
      "answer": "Chain Rule (applied to $y$ as a function of $x$)",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d025",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "The technique of taking $\\ln$ of both sides before differentiating — used especially when the exponent contains $x$ — is called what?",
      "answer": "logarithmic differentiation",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d026",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "The rule that states $(f^{-1})'(b) = \\frac{1}{f'(f^{-1}(b))}$ — i.e., the slope of the inverse is the reciprocal of the slope of $f$ at the reflected point — is called what?",
      "answer": "inverse function derivative rule",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d027",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "The inner function $g$ in a composite $f(g(x))$, whose derivative must be multiplied at the end of the Chain Rule, is informally called what?",
      "answer": "the inside function (or inner function)",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calcbc-u3-d028",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\arctan(g(x))$ using Chain Rule",
      "answer": "\\frac{d}{dx}[\\arctan(g(x))] = \\frac{g'(x)}{1 + [g(x)]^2}",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d029",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\arcsin(g(x))$ using Chain Rule",
      "answer": "\\frac{d}{dx}[\\arcsin(g(x))] = \\frac{g'(x)}{\\sqrt{1 - [g(x)]^2}}",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calcbc-u3-d030",
      "unit": "unit-3",
      "subject": "ap-calculus-bc",
      "mode": "definition_to_term",
      "prompt": "Given the curve $x^2 + y^2 = 25$, the process of differentiating term-by-term with respect to $x$ to find $\\frac{dy}{dx}$ is called what?",
      "answer": "implicit differentiation",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": false
    }
  ]
}
