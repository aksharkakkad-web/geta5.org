      "prompt": "Find the area of $R$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct limits",
          "official_rubric": "1 point: correct limits in an integral in (a), (b), or (c). The limits are $x = -3$ to $x = 3$ (since $\\dfrac{20}{1+x^2} = 2$ when $x = \\pm 3$).",
          "sample_responses": [
            {
              "response": "$\\displaystyle\\int_{-3}^{3} \\left(\\frac{20}{1+x^2} - 2\\right)\\,dx$",
              "earned": true,
              "commentary": "Correctly identifies the intersection points $x = \\pm 3$ by solving $\\frac{20}{1+x^2} = 2 \\Rightarrow x^2 = 9 \\Rightarrow x = \\pm 3$.",
              "source": "cb_guideline"
            },
            {
              "response": "$\\displaystyle\\int_{0}^{3} \\left(\\frac{20}{1+x^2} - 2\\right)\\,dx$",
              "earned": false,
              "commentary": "Only integrates over half the symmetric region; limits must span $-3$ to $3$ (or be doubled correctly).",
              "source": "synthesized"
            }
          ],
          "alternatives": [
            {
              "required_elements": [
                "Lower limit $x=0$, upper limit $x$ where $f=g$"
              ]
