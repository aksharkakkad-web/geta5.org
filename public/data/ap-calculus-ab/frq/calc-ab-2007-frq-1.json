          "sample_responses": [
            {
              "response": "$\\dfrac{20}{1+x^2} - 2$",
              "earned": true,
              "commentary": "Correctly subtracts the lower boundary $y=2$ from the upper boundary $y = \\frac{20}{1+x^2}$.",
              "source": "cb_guideline"
            },
            {
              "response": "$2 - \\dfrac{20}{1+x^2}$",
              "earned": false,
              "commentary": "Integrand is inverted; this gives a negative area because the upper boundary minus lower boundary must be positive on $[-3,3]$.",
