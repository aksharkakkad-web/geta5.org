  "parts": [
    {
      "letter": "a",
      "prompt": "The function $g$ is given by $g(x) = e^{ax} + f(x)$ for all real numbers, where $a$ is a constant. Find $g'(0)$ and $g''(0)$ in terms of $a$. Show the work that leads to your answers.",
      "point_value": 4,
      "scoring_notes": "g'(x) = ae^{ax} + f'(x). g'(0) = a + f'(0) = a - 4. g''(x) = a^2 e^{ax} + f''(x). g''(0) = a^2 + f''(0) = a^2 + 3.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct derivative $g'(x) = ae^{ax} + f'(x)$",
          "alternatives": [
            {
              "required_elements": [
                "$g'(x) = ae^{ax} + f'(x)$"
              ]
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct $g'(0) = a + f'(0) = a - 4$",
          "alternatives": [
            {
              "required_elements": [
                "$g'(0) = a + (-4) = a - 4$"
              ],
              "correct_example": "$g'(0) = ae^0 + f'(0) = a + (-4) = a - 4$"
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct derivative $g''(x) = a^2 e^{ax} + f''(x)$",
