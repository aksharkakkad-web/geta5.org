          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Write an equation for the line tangent to the graph of $f$ at $x = -3$.",
      "point_value": 2,
      "scoring_notes": "From scoring key: $f'(-3) = \\frac{3}{4}$, $f(-3) = 4$. Tangent line: $y = 4 + \\frac{3}{4}(x+3)$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Finds $f'(-3) = \\frac{-(-3)}{\\sqrt{25-9}} = \\frac{3}{4}$ (slope at $x = -3$)",
          "alternatives": [
            {
              "required_elements": [
                "Finds $f'(-3) = \\frac{-(-3)}{\\sqrt{25-9}} = \\frac{3}{4}$ (slope at $x = -3$)"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct tangent line",
          "alternatives": [
            {
              "required_elements": [
                "Correct tangent line"
              ],
              "correct_example": "$f(-3) = \\sqrt{16} = 4$; equation: $y = 4 + \\frac{3}{4}(x+3)$"
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "Let $g$ be the function defined by $g(x) = \\begin{cases} f(x) & \\text{for } -5 \\le x \\le -3 \\\\ x + 7 & \\text{for } -3 < x \\le 5 \\end{cases}$. Is $g$ continuous at $x = -3$? Use the definition of continuity to explain your answer.",
      "point_value": 2,
      "scoring_notes": "From scoring key: Both one-sided limits equal 4, and $g(-3) = f(-3) = 4$. Since $\\lim_{x \\to -3} g(x) = g(-3)$, $g$ is continuous at $x = -3$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Considers both one-sided limits",
          "alternatives": [
            {
              "required_elements": [
                "Considers both one-sided limits"
              ],
              "correct_example": "$\\lim_{x \\to -3^-} g(x) = \\lim_{x \\to -3^-} f(x) = 4$ and $\\lim_{x \\to -3^+} g(x) = \\lim_{x \\to -3^+} (x+7) = 4$"
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct conclusion with justification",
          "alternatives": [
            {
              "required_elements": [
                "Correct conclusion with justification"
              ],
              "correct_example": "$\\lim_{x \\to -3} g(x) = 4 = g(-3)$, so $g$ is continuous at $x = -3$"
            }
          ]
        }
      ]
    },
    {
      "letter": "d",
      "prompt": "Find the value of $\\int_0^5 x\\sqrt{25-x^2}\\, dx$.",
      "point_value": 3,
      "scoring_notes": "From scoring key: $u = 25-x^2$. $\\int_0^5 x\\sqrt{25-x^2}\\, dx = -\\frac{1}{2}\\int_{25}^0 \\sqrt{u}\\, du = -\\frac{1}{3}[u^{3/2}]_0^{25}|$... $= -\\frac{1}{3}(0-125) = \\frac{125}{3}$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "d1",
          "point_value": 1,
          "description": "Uses substitution: let $u = 25 - x^2$, $du = -2x\\, dx$; limits change from $u = 25$ (at $x=0$) to $u = 0$ (at $x=5$)",
          "alternatives": [
            {
              "required_elements": [
                "Uses substitution: let $u = 25 - x^2$, $du = -2x\\, dx$; limits change from $u = 25$ (at $x=0$) to $u = 0$ (at $x=5$)"
              ]
            }
          ]
        },
        {
          "point_id": "d2",
          "point_value": 1,
          "description": "Correct antiderivative",
          "alternatives": [
            {
              "required_elements": [
                "Correct antiderivative"
              ],
              "correct_example": "$\\int x\\sqrt{25-x^2}\\, dx = -\\frac{1}{2}\\int \\sqrt{u}\\, du = -\\frac{1}{3}u^{3/2}$"
            }
          ]
        },
        {
          "point_id": "d3",
          "point_value": 1,
          "description": "Correct answer",
          "alternatives": [
            {
              "required_elements": [
                "Correct answer"
              ],
              "correct_example": "$\\left[-\\frac{1}{3}u^{3/2}\\right]_{25}^0 = -\\frac{1}{3}(0 - 125) = \\frac{125}{3}$"
            }
          ]
        }
      ]
    }
