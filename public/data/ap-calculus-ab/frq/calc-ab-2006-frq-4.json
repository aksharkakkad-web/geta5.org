  "stimulus": "Rocket A has positive velocity $v(t)$ after being launched upward from an initial height of 0 at time $t = 0$. The velocity of the rocket is recorded for selected values of $t$ over the interval $0 \\le t \\le 80$ seconds, as shown in the table above.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Find the average acceleration of rocket A over the time interval $0 \\le t \\le 80$ seconds. Indicate units of measure.",
      "point_value": 1,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct average acceleration with units",
          "alternatives": [
            {
              "required_elements": [
                "$\\tfrac{v(80)-v(0)}{80-0}$",
                "Units ft/sec²"
              ],
              "correct_example": "$\\tfrac{49-5}{80} = \\tfrac{11}{20}$ ft/sec²"
            }
          ],
          "common_traps": [
            "Omitting units or using ft/sec (velocity units)"
          ],
          "official_rubric": "The 1 point in part (a) is earned for the correct value $\\tfrac{v(80) - v(0)}{80 - 0} = \\tfrac{44}{80} = \\tfrac{11}{20}$ ft/sec².",
          "sample_responses": [
            {
              "response": "Avg acceleration $= \\tfrac{v(80)-v(0)}{80} = \\tfrac{44}{80} = \\tfrac{11}{20}$ ft/sec²",
              "earned": true,
              "commentary": "Uses average rate of change formula for acceleration (rate of change of velocity) with units.",
              "source": "synthesized"
            },
            {
              "response": "Avg acceleration $= \\tfrac{11}{20}$",
              "earned": false,
              "commentary": "Missing units ft/sec².",
              "source": "synthesized"
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Using correct units, explain the meaning of $\\int_{10}^{70} v(t)\\, dt$ in terms of the rocket's flight. Use a midpoint Riemann sum with 3 subintervals of equal length to approximate $\\int_{10}^{70} v(t)\\, dt$.",
      "point_value": 3,
      "scoring_notes": null,
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Correct meaning of $\\int_{10}^{70} v(t)\\, dt$",
          "alternatives": [
            {
              "required_elements": [
                "Distance (in feet) traveled by rocket A from $t=10$ to $t=70$ seconds"
