                "Midpoints: $t = 20, 40, 60$",
                "Values: $v(20)=22, v(40)=35, v(60)=44$"
              ],
              "correct_example": "Three subintervals $[10,30], [30,50], [50,70]$ with midpoints $20, 40, 60$."
            }
          ],
          "common_traps": [
            "Using endpoints instead of midpoints"
          ],
          "official_rubric": "2 of 3 points in part (b): identifies correct midpoints $20, 40, 60$ with subinterval width $20$.",
          "sample_responses": [
            {
              "response": "Midpoints: $t=20, 40, 60$; $v=22, 35, 44$.",
