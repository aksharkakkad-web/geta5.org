    },
    {
      "letter": "c",
      "prompt": "Rocket B is launched upward with an acceleration of $a(t) = \\dfrac{3}{\\sqrt{t+1}}$ feet per second per second. At time $t = 0$ seconds, the initial height of the rocket is 0 feet, and the initial velocity is 2 feet per second. Which of the two rockets is traveling faster at time $t = 80$ seconds? Explain your answer.",
      "point_value": 5,
      "scoring_notes": "v_B(t) = 2 + integral from 0 to t of 3/sqrt(s+1) ds. Antiderivative of 3/sqrt(s+1) = 6*sqrt(s+1). So v_B(t) = 2 + 6*sqrt(t+1) - 6 = 6*sqrt(t+1) - 4. v_B(80) = 6*9 - 4 = 50. v_A(80) = 49. Rocket B is faster.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct integral setup for Rocket B's velocity",
          "alternatives": [
            {
              "required_elements": [
                "$v_B(t) = 2 + \\int_0^t \\tfrac{3}{\\sqrt{s+1}}\\, ds$"
              ],
              "correct_example": "$v_B(t) = v_B(0) + \\int_0^t a(s)\\, ds$"
            }
          ],
          "common_traps": [
            "Forgetting initial velocity $2$"
          ],
          "official_rubric": "1 of 4 points in part (c): antiderivative form $6\\sqrt{t+1}$.",
          "sample_responses": [
            {
              "response": "$v_B(t) = 2 + \\int_0^t \\tfrac{3}{\\sqrt{s+1}}\\, ds$",
              "earned": true,
              "commentary": "Correct FTC setup with initial condition.",
              "source": "synthesized"
            },
            {
              "response": "$v_B(t) = \\int_0^t \\tfrac{3}{\\sqrt{s+1}}\\, ds$",
              "earned": false,
              "commentary": "Missing initial velocity.",
              "source": "synthesized"
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct antiderivative $6\\sqrt{s+1}$",
          "alternatives": [
            {
              "required_elements": [
                "$\\int \\tfrac{3}{\\sqrt{s+1}}\\, ds = 6\\sqrt{s+1} + C$"
              ],
              "correct_example": "Antiderivative $6\\sqrt{s+1}$"
            }
          ],
          "common_traps": [
            "Integrating to $3\\sqrt{s+1}$ (forgot the factor of $2$ from substitution)"
          ],
          "official_rubric": "Rubric states: $\\int \\tfrac{3}{\\sqrt{s+1}}\\, ds = 6\\sqrt{s+1} + C$.",
          "sample_responses": [
            {
              "response": "$\\int \\tfrac{3}{\\sqrt{s+1}}\\, ds = 3 \\cdot 2\\sqrt{s+1} = 6\\sqrt{s+1}$",
              "earned": true,
              "commentary": "Correct $u$-substitution gives factor of $2$.",
              "source": "synthesized"
            },
            {
              "response": "$\\int \\tfrac{3}{\\sqrt{s+1}}\\, ds = 3\\sqrt{s+1}$",
              "earned": false,
              "commentary": "Missing factor of $2$ from the substitution.",
              "source": "synthesized"
            }
          ]
        },
        {
          "point_id": "c3",
          "point_value": 1,
          "description": "Correct use of initial condition $v_B(0) = 2$",
          "alternatives": [
            {
              "required_elements": [
                "Adds initial velocity $2$"
              ],
              "correct_example": "$v_B(t) = 6\\sqrt{t+1} - 4$ (since $2 = 6 + C$, $C = -4$)"
            }
          ],
          "common_traps": [
            "Using $v_B(0) = 0$"
          ],
          "official_rubric": "Use of initial condition point: $v_B(0) = 2$ gives $C = -4$.",
          "sample_responses": [
            {
              "response": "$2 = 6 + C \\Rightarrow C = -4$, so $v_B(t) = 6\\sqrt{t+1} - 4$.",
              "earned": true,
              "commentary": "Correctly solves for $C$.",
              "source": "synthesized"
            },
            {
              "response": "$0 = 6 + C \\Rightarrow C = -6$",
              "earned": false,
              "commentary": "Used $v_B(0) = 0$ instead of $2$.",
              "source": "synthesized"
            }
          ]
        },
        {
          "point_id": "c4",
          "point_value": 1,
          "description": "Correct $v_B(80) = 50$ ft/sec and comparison",
          "alternatives": [
            {
              "required_elements": [
                "$v_B(80) = 6\\sqrt{81} - 4 = 50$",
                "$v_A(80) = 49$"
