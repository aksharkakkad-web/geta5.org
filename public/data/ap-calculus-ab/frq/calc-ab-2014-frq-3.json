          "description": "Applies chain rule",
          "alternatives": [
            {
              "required_elements": [
                "Applies chain rule"
              ],
              "correct_example": "$p'(x) = f'(x^2 - x) \\cdot (2x - 1)$"
            }
          ]
        },
        {
          "point_id": "d2",
