          "sample_responses": [
            {
              "response": "$k\\cdot\\dfrac{1}{2k} + \\ln\\dfrac{1}{\\sqrt{2k}} = 0 \\Rightarrow \\dfrac{1}{2} - \\dfrac{1}{2}\\ln(2k) = 0$",
              "earned": true,
              "commentary": "$kx_0^2 = k\\cdot\\frac{1}{2k} = \\frac{1}{2}$ and $\\ln\\frac{1}{\\sqrt{2k}} = -\\frac{1}{2}\\ln(2k)$.",
