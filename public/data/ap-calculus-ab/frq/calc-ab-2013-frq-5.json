  ],
  "calculator_allowed": false,
  "total_points": 9,
  "stimulus": "Let $f(x) = 2x^2 - 6x + 4$ and $g(x) = 4\\cos\\left(\\frac{\\pi x}{4}\\right)$. Let $R$ be the region bounded by the graphs of $f$ and $g$, as shown in the figure.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Find the area of $R$.",
      "point_value": 4,
      "scoring_notes": "From scoring key: Area $= \\int_0^2 \\left[4\\cos\\left(\\frac{\\pi x}{4}\\right) - (2x^2-6x+4)\\right]\\, dx = \\left[\\frac{16}{\\pi}\\sin\\frac{\\pi x}{4} - \\frac{2x^3}{3}+3x^2-4x\\right]_0^2 = \\frac{16}{\\pi} - \\frac{4}{3}$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct limits",
          "alternatives": [
            {
              "required_elements": [
                "Correct limits"
              ],
              "correct_example": "$x = 0$ and $x = 2$ (intersection points of $f$ and $g$)"
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct integrand",
          "alternatives": [
            {
              "required_elements": [
                "Correct integrand"
              ],
              "correct_example": "$g(x) - f(x) = 4\\cos\\left(\\frac{\\pi x}{4}\\right) - (2x^2 - 6x + 4)$"
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct antiderivative",
          "alternatives": [
            {
              "required_elements": [
                "Correct antiderivative"
              ],
              "correct_example": "$\\frac{16}{\\pi}\\sin\\left(\\frac{\\pi x}{4}\\right) - \\frac{2x^3}{3} + 3x^2 - 4x$"
            }
          ]
        },
        {
          "point_id": "a4",
          "point_value": 1,
          "description": "Correct answer",
          "alternatives": [
            {
              "required_elements": [
                "Correct answer"
              ],
              "correct_example": "$\\frac{16}{\\pi} - \\frac{4}{3}$"
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Write, but do not evaluate, an integral expression that gives the volume of the solid generated when $R$ is rotated about the horizontal line $y = 4$.",
      "point_value": 3,
      "scoring_notes": "From scoring key: Volume $= \\pi\\int_0^2 \\left[(4-f(x))^2 - (4-g(x))^2\\right]\\, dx$ (do not evaluate).",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Uses washer method with correct limits ($0$ to $2$) and constant $\\pi$",
          "alternatives": [
            {
              "required_elements": [
                "Uses washer method with correct limits ($0$ to $2$)",
                "constant $\\pi$"
              ]
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct outer radius",
          "alternatives": [
            {
              "required_elements": [
                "Correct outer radius"
              ],
              "correct_example": "$4 - f(x) = 4 - (2x^2-6x+4) = -2x^2+6x$; correct inner radius: $4 - g(x) = 4 - 4\\cos(\\frac{\\pi x}{4})$"
            }
          ]
        },
        {
          "point_id": "b3",
          "point_value": 1,
          "description": "Correct expression",
          "alternatives": [
            {
              "required_elements": [
                "Correct expression"
              ],
              "correct_example": "$\\pi\\int_0^2 \\left[(4-f(x))^2 - (4-g(x))^2\\right]\\, dx$"
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "The region $R$ is the base of a solid. For this solid, each cross section perpendicular to the $x$-axis is a square. Write, but do not evaluate, an integral expression that gives the volume of the solid.",
      "point_value": 2,
      "scoring_notes": "From scoring key: Volume $= \\int_0^2 \\left[4\\cos\\left(\\frac{\\pi x}{4}\\right) - (2x^2-6x+4)\\right]^2\\, dx$ (do not evaluate).",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Correct integrand",
          "alternatives": [
            {
              "required_elements": [
                "Correct integrand"
              ],
              "correct_example": "$[g(x) - f(x)]^2$"
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct expression with limits",
          "alternatives": [
            {
              "required_elements": [
                "Correct expression with limits"
              ],
              "correct_example": "$\\int_0^2 \\left[g(x) - f(x)\\right]^2\\, dx$"
            }
          ]
        }
      ]
    }
  ],
