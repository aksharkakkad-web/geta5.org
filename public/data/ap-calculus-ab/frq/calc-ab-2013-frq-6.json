  "title": "dy/dx = e^y(3x²-6x) — Tangent Line Approx & Separation of Variables",
  "frq_type": "multi_part_math",
  "related_units": [
    3,
    7
  ],
  "calculator_allowed": false,
  "total_points": 9,
  "stimulus": "Consider the differential equation $\\frac{dy}{dx} = e^y(3x^2 - 6x)$. Let $y = f(x)$ be the particular solution to the differential equation that passes through $(1, 0)$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Write an equation for the line tangent to the graph of $f$ at the point $(1, 0)$. Use the tangent line to approximate $f(1.2)$.",
      "point_value": 3,
      "scoring_notes": "From scoring key: Slope at $(1,0)$: $e^0(3-6) = -3$. Tangent line: $y = -3(x-1)$. $f(1.2) \\approx -0.6$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Evaluates slope",
          "alternatives": [
            {
              "required_elements": [
                "Evaluates slope"
              ],
              "correct_example": "$\\frac{dy}{dx}\\big|_{(1,0)} = e^0(3(1)^2 - 6(1)) = 1 \\cdot (-3) = -3$"
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Tangent line equation",
          "alternatives": [
            {
              "required_elements": [
                "Tangent line equation"
              ],
              "correct_example": "$y = -3(x - 1)$"
            }
          ]
        },
        {
          "point_id": "a3",
          "point_value": 1,
          "description": "Correct approximation",
          "alternatives": [
            {
              "required_elements": [
                "Correct approximation"
              ],
              "correct_example": "$f(1.2) \\approx -3(1.2 - 1) = -0.6$"
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Find $y = f(x)$, the particular solution to the differential equation that passes through $(1, 0)$.",
      "point_value": 6,
      "scoring_notes": "From scoring key: $\\int e^{-y}\\, dy = \\int(3x^2-6x)\\, dx \\Rightarrow -e^{-y} = x^3-3x^2+C$. Using $(1,0)$: $C=1$. Solving: $y = -\\ln(-x^3+3x^2-1)$. Valid on interval containing $x=1$ where $-x^3+3x^2-1>0$. 0/6 if no separation; max 3/6 if no constant.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Separates variables",
          "alternatives": [
            {
              "required_elements": [
                "Separates variables"
              ],
              "correct_example": "$e^{-y}\\, dy = (3x^2 - 6x)\\, dx$"
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Correct antiderivative (left side)",
          "alternatives": [
            {
              "required_elements": [
                "Correct antiderivative (left side)"
              ],
              "correct_example": "$-e^{-y}$"
            }
          ]
        },
        {
          "point_id": "b3",
          "point_value": 1,
          "description": "Correct antiderivative (right side)",
          "alternatives": [
            {
              "required_elements": [
                "Correct antiderivative (right side)"
              ],
              "correct_example": "$x^3 - 3x^2 + C$"
            }
          ]
        },
        {
          "point_id": "b4",
          "point_value": 1,
          "description": "Includes constant of integration and uses initial condition $(1, 0)$",
          "alternatives": [
            {
              "required_elements": [
                "Includes constant of integration",
                "uses initial condition $(1, 0)$"
              ],
              "correct_example": "$-e^0 = 1 - 3 + C \\Rightarrow -1 = -2 + C \\Rightarrow C = 1$"
            }
          ]
        },
        {
          "point_id": "b5",
          "point_value": 1,
          "description": "Solves for $y$",
          "alternatives": [
            {
              "required_elements": [
                "Solves for $y$"
              ],
              "correct_example": "$-e^{-y} = x^3 - 3x^2 + 1$; $e^{-y} = -x^3 + 3x^2 - 1$; $-y = \\ln(-x^3 + 3x^2 - 1)$"
            }
          ]
        },
        {
          "point_id": "b6",
          "point_value": 1,
          "description": "Final answer",
          "alternatives": [
            {
              "required_elements": [
                "Final answer"
              ],
              "correct_example": "$y = f(x) = -\\ln(-x^3 + 3x^2 - 1)$"
            }
          ]
        }
      ]
    }
  ]
}