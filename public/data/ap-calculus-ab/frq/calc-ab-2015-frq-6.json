{
  "id": "calc-ab-2015-frq-6",
  "subject": "ap-calculus-ab",
  "year": 2015,
  "source": "released",
  "title": "Curve y³ - xy = 2 — Tangent Line, Vertical Tangent Points & Second Derivative",
  "frq_type": "multi_part_math",
  "related_units": [
    2,
    3
  ],
  "calculator_allowed": false,
  "total_points": 9,
  "stimulus": "Consider the curve given by the equation $y^3 - xy = 2$. It can be shown that $\\frac{dy}{dx} = \\frac{y}{3y^2 - x}$.",
  "stimulus_image": null,
  "documents": null,
  "parts": [
    {
      "letter": "a",
      "prompt": "Write an equation for the line tangent to the curve at the point $(-1, 1)$.",
      "point_value": 2,
      "scoring_notes": "From scoring key: Slope $= \\frac{1}{3(1)-(-1)} = \\frac{1}{4}$. Tangent line: $y = 1 + \\frac{1}{4}(x+1)$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "a1",
          "point_value": 1,
          "description": "Correct slope at $(-1, 1)$",
          "alternatives": [
            {
              "required_elements": [
                "Correct slope at $(-1, 1)$"
              ],
              "correct_example": "$\\frac{dy}{dx}\\big|_{(-1,1)} = \\frac{1}{3(1)^2 - (-1)} = \\frac{1}{4}$"
            }
          ]
        },
        {
          "point_id": "a2",
          "point_value": 1,
          "description": "Correct tangent line equation",
          "alternatives": [
            {
              "required_elements": [
                "Correct tangent line equation"
              ],
              "correct_example": "$y = \\frac{1}{4}(x+1) + 1$ or equivalent"
            }
          ]
        }
      ]
    },
    {
      "letter": "b",
      "prompt": "Find the coordinates of all points on the curve at which the line tangent to the curve at that point is vertical.",
      "point_value": 3,
      "scoring_notes": "From scoring key: $3y^2 - x = 0 \\Rightarrow x = 3y^2$. Substituting: $y^3 - 3y^3 = 2 \\Rightarrow y = -1$. Then $x = 3$. Vertical tangent at $(3, -1)$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "b1",
          "point_value": 1,
          "description": "Sets denominator equal to zero",
          "alternatives": [
            {
              "required_elements": [
                "Sets denominator equal to zero"
              ],
              "correct_example": "$3y^2 - x = 0 \\Rightarrow x = 3y^2$"
            }
          ]
        },
        {
          "point_id": "b2",
          "point_value": 1,
          "description": "Substitutes into curve equation",
          "alternatives": [
            {
              "required_elements": [
                "Substitutes into curve equation"
              ],
              "correct_example": "$y^3 - (3y^2)(y) = 2 \\Rightarrow y^3 - 3y^3 = 2 \\Rightarrow -2y^3 = 2 \\Rightarrow y = -1$"
            }
          ]
        },
        {
          "point_id": "b3",
          "point_value": 1,
          "description": "Correct coordinates",
          "alternatives": [
            {
              "required_elements": [
                "Correct coordinates"
              ],
              "correct_example": "$x = 3(-1)^2 = 3$; point is $(3, -1)$"
            }
          ]
        }
      ]
    },
    {
      "letter": "c",
      "prompt": "Evaluate $\\frac{d^2y}{dx^2}$ at the point on the curve where $x = -1$ and $y = 1$.",
      "point_value": 4,
      "scoring_notes": "From scoring key: $\\frac{d^2y}{dx^2} = \\frac{(3y^2-x)\\frac{dy}{dx} - y(6y\\frac{dy}{dx}-1)}{(3y^2-x)^2}$. At $(-1,1)$ with $\\frac{dy}{dx}=\\frac{1}{4}$: numerator $= 4 \\cdot \\frac{1}{4} - 1 \\cdot (\\frac{6}{4}-1) = 1 - \\frac{1}{2} = \\frac{1}{2}$; denominator $= 16$. Answer: $\\frac{1}{32}$.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Differentiates $\\frac{dy}{dx} = \\frac{y}{3y^2 - x}$ implicitly using quotient rule",
          "alternatives": [
            {
              "required_elements": [
                "Differentiates $\\frac{dy}{dx} = \\frac{y}{3y^2 - x}$ implicitly using quotient rule"
              ]
            }
          ]
        },
        {
          "point_id": "c2",
          "point_value": 1,
          "description": "Correct expression",
          "alternatives": [
            {
              "required_elements": [
                "Correct expression"
              ],
              "correct_example": "$\\frac{d^2y}{dx^2} = \\frac{(3y^2-x)\\frac{dy}{dx} - y(6y\\frac{dy}{dx} - 1)}{(3y^2-x)^2}$"
            }
          ]
        },
        {
          "point_id": "c3",
          "point_value": 1,
          "description": "Substitutes $x = -1$, $y = 1$, $\\frac{dy}{dx} = \\frac{1}{4}$",
          "alternatives": [
            {
              "required_elements": [
                "Substitutes $x = -1$, $y = 1$, $\\frac{dy}{dx} = \\frac{1}{4}$"
              ]
            }
          ]
        },
        {
          "point_id": "c4",
          "point_value": 1,
          "description": "Correct answer",
          "alternatives": [
            {
              "required_elements": [
                "Correct answer"
              ],
              "correct_example": "$\\frac{d^2y}{dx^2}\\bigg|_{(-1,1)} = \\frac{4 \\cdot \\frac{1}{4} - 1 \\cdot (6 \\cdot 1 \\cdot \\frac{1}{4} - 1)}{16} = \\frac{1 - 1 \\cdot \\frac{1}{2}}{16} = \\frac{\\frac{1}{2}}{16} = \\frac{1}{32}$"
            }
          ]
        }
      ]
    }
  ],
