            }
          ]
        },
        {
          "point_id": "c4",
          "point_value": 1,
          "description": "Includes constant of integration and uses initial condition $f(0) = 1$",
          "alternatives": [
            {
              "required_elements": [
                "Includes constant of integration",
                "uses initial condition $f(0) = 1$"
              ],
              "correct_example": "$-\\ln(2) = 0 + C \\Rightarrow C = -\\ln 2$"
            }
