    {
      "letter": "c",
      "prompt": "Find $y = f(x)$, the particular solution to the differential equation with the initial condition $f(0) = 1$.",
      "point_value": 6,
      "scoring_notes": "From scoring key: $\\frac{dy}{3-y} = \\cos x\\, dx$. $-\\ln|3-y| = \\sin x + C$. Using $f(0)=1$: $C = -\\ln 2$. Since $y < 3$: $3 - y = 2e^{-\\sin x}$, so $y = 3 - 2e^{-\\sin x}$. Valid for all real $x$. 0/6 if no separation; max 3/6 if no constant of integration.",
      "requires_drawing": false,
      "reference_image": null,
      "scoring_points": [
        {
          "point_id": "c1",
          "point_value": 1,
          "description": "Separates variables",
          "alternatives": [
            {
              "required_elements": [
                "Separates variables"
              ],
              "correct_example": "$\\frac{dy}{3-y} = \\cos x\\, dx$"
            }
          ]
