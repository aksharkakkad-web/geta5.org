{
  "subject": "ap-calculus-ab",
  "unit": "unit-2",
  "unit_name": "Differentiation: Definition and Fundamental Properties",
  "cards": [
    {
      "id": "calc-u2-d001",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Definition of the derivative (limit form)",
      "answer": "f'(x) = \\lim_{h \\to 0} \\frac{f(x+h) - f(x)}{h}",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d002",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Average rate of change of $f$ on $[a, b]$",
      "answer": "\\frac{f(b) - f(a)}{b - a}",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d003",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Power Rule: derivative of $x^n$",
      "answer": "\\frac{d}{dx}[x^n] = nx^{n-1}",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d004",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Constant Rule: derivative of a constant $c$",
      "answer": "\\frac{d}{dx}[c] = 0",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d005",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Constant Multiple Rule: derivative of $c \\cdot f(x)$",
      "answer": "\\frac{d}{dx}[c \\cdot f(x)] = c \\cdot f'(x)",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d006",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Sum/Difference Rule: derivative of $f(x) \\pm g(x)$",
      "answer": "\\frac{d}{dx}[f(x) \\pm g(x)] = f'(x) \\pm g'(x)",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d007",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Product Rule: derivative of $f(x) \\cdot g(x)$",
      "answer": "\\frac{d}{dx}[f(x) \\cdot g(x)] = f'(x)g(x) + f(x)g'(x)",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d008",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Quotient Rule: derivative of $\\frac{f(x)}{g(x)}$",
      "answer": "\\frac{d}{dx}\\left[\\frac{f(x)}{g(x)}\\right] = \\frac{f'(x)g(x) - f(x)g'(x)}{[g(x)]^2}",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d009",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\sin x$",
      "answer": "\\frac{d}{dx}[\\sin x] = \\cos x",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d010",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\cos x$",
      "answer": "\\frac{d}{dx}[\\cos x] = -\\sin x",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d011",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $e^x$",
      "answer": "\\frac{d}{dx}[e^x] = e^x",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d012",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\ln x$",
      "answer": "\\frac{d}{dx}[\\ln x] = \\frac{1}{x}",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d013",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\tan x$",
      "answer": "\\frac{d}{dx}[\\tan x] = \\sec^2 x",
      "is_key_term": true,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d014",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\cot x$",
      "answer": "\\frac{d}{dx}[\\cot x] = -\\csc^2 x",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d015",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\sec x$",
      "answer": "\\frac{d}{dx}[\\sec x] = \\sec x \\tan x",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d016",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $\\csc x$",
      "answer": "\\frac{d}{dx}[\\csc x] = -\\csc x \\cot x",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d017",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Point-slope form of the tangent line to $f$ at $x = a$",
      "answer": "y - f(a) = f'(a)(x - a)",
      "is_key_term": true,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d018",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Alternate form of derivative definition at $x = a$",
      "answer": "f'(a) = \\lim_{x \\to a} \\frac{f(x) - f(a)}{x - a}",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d019",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Leibniz notation for the derivative of $y$ with respect to $x$",
      "answer": "\\frac{dy}{dx}",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d020",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Derivative of $a^x$ ($a > 0$, $a \\neq 1$)",
      "answer": "\\frac{d}{dx}[a^x] = a^x \\ln a",
      "is_key_term": false,
      "difficulty": "hard",
      "katex_required": true
    },
    {
      "id": "calc-u2-d021",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Second derivative notation (Leibniz form)",
      "answer": "\\frac{d^2y}{dx^2}",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d022",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "name_to_formula",
      "prompt": "Slope of the normal line to $f$ at $x = a$",
      "answer": "-\\frac{1}{f'(a)}",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d023",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The instantaneous rate of change of a function at a point; the slope of the tangent line at that point",
      "answer": "derivative",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calc-u2-d024",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The expression $\\frac{f(a+h) - f(a)}{h}$, which gives the slope of the secant line between two points",
      "answer": "difference quotient",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": true
    },
    {
      "id": "calc-u2-d025",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "A line that touches the graph of a function at exactly one point and has slope equal to the derivative at that point",
      "answer": "tangent line",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calc-u2-d026",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The property of a function at a point where the limit of the difference quotient exists; implies continuity at that point",
      "answer": "differentiability",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": false
    },
    {
      "id": "calc-u2-d027",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "If a function has this property at a point, then it must be continuous there, but the converse is not always true",
      "answer": "differentiability",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": false
    },
    {
      "id": "calc-u2-d028",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The derivative of the derivative of a function; measures how fast the rate of change is itself changing",
      "answer": "second derivative",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": false
    },
    {
      "id": "calc-u2-d029",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "A line perpendicular to the tangent line at a point on a curve",
      "answer": "normal line",
      "is_key_term": false,
      "difficulty": "medium",
      "katex_required": false
    },
    {
      "id": "calc-u2-d030",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The slope of the secant line between $(a, f(a))$ and $(b, f(b))$; equals $\\frac{f(b)-f(a)}{b-a}$",
      "answer": "average rate of change",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d031",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The rule that lets you find the derivative of a product of two functions: $(fg)' = f'g + fg'$",
      "answer": "Product Rule",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    },
    {
      "id": "calc-u2-d032",
      "unit": "unit-2",
      "subject": "ap-calculus-ab",
      "mode": "definition_to_term",
      "prompt": "The rule for differentiating a ratio of two functions: $(f/g)' = (f'g - fg')/g^2$",
      "answer": "Quotient Rule",
      "is_key_term": false,
      "difficulty": "easy",
      "katex_required": true
    }
  ]
}
